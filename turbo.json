{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NODE_ENV","NEXT_PUBLIC_SUPABASE_URL","NEXT_PUBLIC_SUPABASE_ANON_KEY","SUPABASE_SERVICE_ROLE_KEY","RAILWAY_ENVIRONMENT"],
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": [".next/**","!.next/cache/**","dist/**","build/**"] },
    "dev": { "cache": false, "persistent": true },
    "lint": { "dependsOn": ["^lint"] },
    "test": { "dependsOn": ["^build"], "outputs": ["coverage/**"] },
    "audit": { "cache": false, "outputs": ["audit-report/**"] },
    "type-check": { "dependsOn": ["^build"] },
    "clean": { "cache": false }
  }
}
